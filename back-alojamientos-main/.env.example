# Copy this file to .env and fill with real values before running docker compose

DB_PASSWORD=CHANGE_ME
JWT_KEY=CHANGE_ME_WITH_LONG_RANDOM_SECRET
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
EMAIL_USERNAME=
EMAIL_PASSWORD=
CORS_ALLOWED_ORIGIN_0=http://YOUR_FRONTEND_HOST
CORS_ALLOWED_ORIGIN_1=

# Optional: override API image tag used by docker compose in production
API_IMAGE=ghcr.io/113012davidt/arroyo-seco-api:latest
