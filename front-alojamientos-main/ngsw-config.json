{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "appData": {
    "version": "2"
  },
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/env.js",
          "/manifest-v2.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/**/*.(svg|cur|jpg|jpeg|png|apng|webp|avif|gif|otf|ttf|woff|woff2)"
        ]
      }
    }
  ],
  "navigationUrls": [
    "/**",
    "!/**/*.*",
    "!/api/**"
  ],
  "navigationRequestStrategy": "freshness",
  "dataGroups": [
    {
      "name": "api-listas-fresh",
      "urls": [
        "/api/Gastronomias",
        "/api/Gastronomias/**",
        "/api/Alojamientos",
        "/api/Alojamientos/**"
      ],
      "cacheConfig": {
        "maxSize": 100,
        "maxAge": "12h",
        "timeout": "5s",
        "strategy": "freshness"
      }
    },
    {
      "name": "api-reviews-fresh",
      "urls": [
        "/api/Gastronomias/*/reviews"
      ],
      "cacheConfig": {
        "maxSize": 100,
        "maxAge": "30m",
        "timeout": "5s",
        "strategy": "freshness"
      }
    },
    {
      "name": "api-performance",
      "urls": [
        "/api/Gastronomias/*/menus",
        "/api/Gastronomias/*/disponibilidad"
      ],
      "cacheConfig": {
        "maxSize": 100,
        "maxAge": "24h",
        "timeout": "3s",
        "strategy": "performance"
      }
    },
    {
      "name": "api-public-images",
      "urls": [
        "/api/Storage/public/**",
        "/comprobantes/**"
      ],
      "cacheConfig": {
        "maxSize": 300,
        "maxAge": "30d",
        "timeout": "3s",
        "strategy": "performance"
      }
    },
    {
      "name": "api-auth",
      "urls": [
        "/api/Auth/**"
      ],
      "cacheConfig": {
        "maxSize": 10,
        "maxAge": "0s",
        "timeout": "5s",
        "strategy": "freshness"
      }
    }
  ]
}
