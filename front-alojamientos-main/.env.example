# Copy this file to .env on the server before running docker compose

# Browser-facing API base path (recommended for PWA caching)
API_BASE_URL=/api

# Upstream backend target used by nginx proxy inside the container
API_UPSTREAM=http://host.docker.internal:8080

# Optional: override frontend image tag used by docker compose in production
FRONT_IMAGE=ghcr.io/113012davidt/arroyo-seco-front:latest
